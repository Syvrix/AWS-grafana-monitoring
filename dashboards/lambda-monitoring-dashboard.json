{
  "__inputs": [
    {
      "name": "DS_CLOUDWATCH",
      "label": "CloudWatch",
      "description": "Your CloudWatch data source",
      "type": "datasource",
      "pluginId": "cloudwatch",
      "pluginName": "CloudWatch"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "cloudwatch", "name": "CloudWatch", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Lambda function monitoring — errors, RDS connection success/failure, and log explorer",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Summary",
      "type": "row"
    },

    {
      "id": 1,
      "title": "Total invocations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "expression": "",
          "id": "",
          "matchExact": true,
          "metricEditorMode": 0,
          "metricName": "Invocations",
          "metricQueryType": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "Sum"
        }
      ]
    },

    {
      "id": 2,
      "title": "Total errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Errors",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "Sum"
        }
      ]
    },

    {
      "id": 3,
      "title": "Error rate %",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Errors",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "errors",
          "region": "$region",
          "statistic": "Sum"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Invocations",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "invocations",
          "region": "$region",
          "statistic": "Sum",
          "hide": true
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "errors / invocations * 100",
          "id": "errorrate",
          "metricQueryType": 0,
          "metricEditorMode": 1,
          "refId": "C",
          "region": "$region",
          "hide": false
        }
      ]
    },

    {
      "id": 4,
      "title": "p99 duration (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Duration",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "p99"
        }
      ]
    },

    {
      "id": 5,
      "title": "Throttles",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Throttles",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "Sum"
        }
      ]
    },

    {
      "id": 6,
      "title": "Cold starts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "InitDuration",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "SampleCount"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Errors & invocations",
      "type": "row"
    },

    {
      "id": 10,
      "title": "Invocations vs errors over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Invocations" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "alias": "Invocations",
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Invocations",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "Sum"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "alias": "Errors",
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Errors",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "B",
          "region": "$region",
          "statistic": "Sum"
        }
      ]
    },

    {
      "id": 11,
      "title": "Duration — p50 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 6, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "alias": "p50",
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Duration",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "p50"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "alias": "p99",
          "dimensions": { "FunctionName": ["$function_name"] },
          "metricName": "Duration",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/Lambda",
          "period": "$period",
          "refId": "B",
          "region": "$region",
          "statistic": "p99"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "RDS connection monitoring",
      "type": "row"
    },

    {
      "id": 20,
      "title": "Successful RDS connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "description": "Count of log lines matching a successful DB connection. Requires your Lambda to log a success message e.g. 'DB connection established'.",
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "alias": "Successful connections",
          "expression": "fields @timestamp, @message\n| filter @message like /(?i)(connected|connection established|DB connection|database connected|RDS connected|acquired connection)/\n| stats count() as successes by bin($period)",
          "id": "",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "namespace": "AWS/Lambda",
          "queryMode": "Logs",
          "refId": "A",
          "region": "$region",
          "statsGroups": ["bin($period)"]
        }
      ]
    },

    {
      "id": 21,
      "title": "Failed RDS connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "description": "Count of log lines matching a failed DB connection or timeout.",
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "fields @timestamp, @message\n| filter @message like /(?i)(connection refused|could not connect|ECONNREFUSED|connection timeout|connection failed|unable to connect|Access denied|OperationalError|ETIMEDOUT)/\n| stats count() as failures by bin($period)",
          "id": "",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "namespace": "AWS/Lambda",
          "queryMode": "Logs",
          "refId": "A",
          "region": "$region",
          "statsGroups": ["bin($period)"]
        }
      ]
    },

    {
      "id": 22,
      "title": "RDS DB connections (CloudWatch metric)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 15 },
      "description": "Active connections on the RDS instance itself. High numbers can indicate connection pool exhaustion.",
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "alias": "DB connections",
          "dimensions": { "DBInstanceIdentifier": ["$rds_instance"] },
          "metricName": "DatabaseConnections",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "namespace": "AWS/RDS",
          "period": "$period",
          "refId": "A",
          "region": "$region",
          "statistic": "Average"
        }
      ]
    },

    {
      "id": 23,
      "title": "RDS connection success vs failure over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failures" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "successes" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "fields @timestamp, @message\n| filter @message like /(?i)(connected|connection established|DB connection|database connected|RDS connected|acquired connection)/\n| stats count() as successes by bin($period)",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "queryMode": "Logs",
          "refId": "A",
          "region": "$region",
          "statsGroups": ["bin($period)"]
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "fields @timestamp, @message\n| filter @message like /(?i)(connection refused|could not connect|ECONNREFUSED|connection timeout|connection failed|unable to connect|Access denied|OperationalError|ETIMEDOUT)/\n| stats count() as failures by bin($period)",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "queryMode": "Logs",
          "refId": "B",
          "region": "$region",
          "statsGroups": ["bin($period)"]
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Log explorer",
      "type": "row"
    },

    {
      "id": 30,
      "title": "All errors & warnings",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "fields @timestamp, @message, @logStream\n| filter @message like /(?i)(ERROR|WARN|Exception|Traceback|fatal|critical)/\n| sort @timestamp desc\n| limit 200",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "queryMode": "Logs",
          "refId": "A",
          "region": "$region"
        }
      ]
    },

    {
      "id": 31,
      "title": "RDS connection log events",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 28 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "fields @timestamp, @message, @logStream\n| filter @message like /(?i)(connect|RDS|database|postgres|mysql|aurora|pg|sequelize|knex|prisma|pool|ECONNREFUSED|ETIMEDOUT)/\n| sort @timestamp desc\n| limit 200",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "queryMode": "Logs",
          "refId": "A",
          "region": "$region"
        }
      ]
    },

    {
      "id": 32,
      "title": "API request log events",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "fields @timestamp, @message, @logStream\n| filter @message like /(?i)(GET|POST|PUT|DELETE|PATCH|http|https|axios|fetch|request|response|status|statusCode|200|201|4[0-9]{2}|5[0-9]{2})/\n| sort @timestamp desc\n| limit 200",
          "logGroups": [{ "name": "/aws/lambda/$function_name" }],
          "queryMode": "Logs",
          "refId": "A",
          "region": "$region"
        }
      ]
    }

  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["lambda", "cloudwatch", "rds", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
        "definition": "regions()",
        "hide": 0,
        "includeAll": false,
        "label": "Region",
        "multi": false,
        "name": "region",
        "options": [],
        "query": "regions()",
        "refresh": 1,
        "sort": 0,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
        "definition": "dimension_values($region,AWS/Lambda,Invocations,FunctionName)",
        "hide": 0,
        "includeAll": true,
        "allValue": "*",
        "label": "Function name",
        "multi": true,
        "name": "function_name",
        "options": [],
        "query": "dimension_values($region,AWS/Lambda,Invocations,FunctionName)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
        "definition": "dimension_values($region,AWS/RDS,DatabaseConnections,DBInstanceIdentifier)",
        "hide": 0,
        "includeAll": true,
        "allValue": "*",
        "label": "RDS instance",
        "multi": false,
        "name": "rds_instance",
        "options": [],
        "query": "dimension_values($region,AWS/RDS,DatabaseConnections,DBInstanceIdentifier)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "300", "value": "300" },
        "hide": 0,
        "includeAll": false,
        "label": "Period (seconds)",
        "multi": false,
        "name": "period",
